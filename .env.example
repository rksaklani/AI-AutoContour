# ─────────────────────────────────────────────────────────────
# AI-AutoContour environment configuration
# Copy to `.env` and adjust. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Branding (rename the platform here) ---
APP_NAME=AI-AutoContour

# --- Core API ---
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
# Comma separated list of allowed CORS origins
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- PostgreSQL ---
POSTGRES_USER=ai_autocontour
POSTGRES_PASSWORD=ai_autocontour
POSTGRES_DB=ai_autocontour
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (broker + cache + pubsub) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- MinIO / S3 ---
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ai-autocontour
S3_SECRET_KEY=ai-autocontour-secret
S3_BUCKET=ai-autocontour
S3_REGION=us-east-1
S3_SECURE=false

# --- MinIO root creds (used by the minio container) ---
MINIO_ROOT_USER=ai-autocontour
MINIO_ROOT_PASSWORD=ai-autocontour-secret

# --- Seed admin user ---
FIRST_ADMIN_EMAIL=admin@ai-autocontour.dev
FIRST_ADMIN_PASSWORD=admin12345

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# --- AI engine ---
# stub = local deterministic engine (no sidecar)
# vila_m3 = MONAI VILA-M3 sidecar
AI_ENGINE=vila_m3
VILA_M3_URL=http://localhost:8100
VILA_M3_TIMEOUT_SEC=300
VILA_M3_FALLBACK_STUB=true

# Sidecar mode: lite (CPU demo) | vila (full GPU — use docker-compose.gpu.yml)
VILA_M3_MODE=lite
VILA_M3_SOURCE=local
VILA_M3_MODEL_ID=MONAI/Llama3-VILA-M3-8B
VILA_M3_MODEL_PATH=/data/checkpoints/Llama3-VILA-M3-8B
VILA_M3_CONV_MODE=llama_3
# Alternatives: MONAI/Llama3-VILA-M3-3B (less VRAM) | MONAI/Llama3-VILA-M3-13B (more VRAM)
